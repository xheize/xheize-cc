# Authentik SSO 설정
# Authentik 대시보드에서 OAuth2/OpenID 애플리케이션을 생성하고 아래 값을 입력하세요

# Authentik OIDC Issuer URL
# 예: https://authentik.yourdomain.com/application/o/your-app-slug/
AUTHENTIK_ISSUER=https://authentik.company/application/o/your-app/

# OAuth2 클라이언트 ID
AUTHENTIK_CLIENT_ID=your-client-id-here

# OAuth2 클라이언트 시크릿
AUTHENTIK_CLIENT_SECRET=your-client-secret-here

# Auth.js 비밀키 (랜덤한 문자열 생성)
# 생성 방법: openssl rand -base64 32
AUTH_SECRET=change-this-to-a-random-secret-string

# 애플리케이션 URL (프로덕션에서는 실제 도메인 사용)
AUTH_URL=http://localhost:5173
